# Copy to .env.local for local development:  cp .env.example .env.local
# Every value below is also the built-in default, so the web app works with no
# .env.local at all as long as the API is running on http://localhost:8088.

# MH4U API base URL.
#   API_BASE_URL             — used for server-side requests (SSR / route handlers)
#   NEXT_PUBLIC_API_BASE_URL — used for requests made from the browser
API_BASE_URL=http://localhost:8088/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8088/api/v1

# Hostname that serves game images (next/image remote patterns). Host only —
# no scheme or port. "localhost" for local dev, or your CDN host in production.
NEXT_PUBLIC_ASSET_HOST=localhost

# OpenAPI spec used by `npm run generate:api` to regenerate the typed API client
# (src/lib/api/schema.d.ts) from the running API.
API_DOCS_URL=http://localhost:8088/docs.openapi
